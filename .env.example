# =============================================
# Liga de Wiffle Ball Venezolana
# Plantilla de Variables de Entorno
# Copia este archivo como .env.local y reemplaza los valores
# =============================================

# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anónima (pública, segura para el frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima_aqui

# Clave de servicio (SECRETA - solo para el servidor)
SUPABASE_SERVICE_ROLE_KEY=tu_clave_service_role_aqui
